# --- Base de données ---
DATABASE_URL="file:./dev.db"

# --- Serveur HTTP ---
PORT=3001
NODE_ENV=development

# --- Session (cookie signé, min. 16 caractères aléatoires en prod) ---
SESSION_SECRET="change-moi-en-production-tres-long-secret"

# --- OAuth2 Discord (https://discord.com/developers/applications) ---
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# Jeton du bot (Bot → Reset token) : même application que CLIENT_ID, pour inviter / vérifier la présence
DISCORD_BOT_TOKEN=""
# Laisser VIDE pour que l’URL de retour OAuth soit calculée selon l’adresse qui appelle l’API
# (ex. http://192.168.0.250:3001/api/auth/callback). Chaque URL utilisée doit être ajoutée dans
# le portail Discord → OAuth2 → Redirects. Si tu mets une valeur ici, elle remplace le calcul auto.
DISCORD_REDIRECT_URI=

# --- Panel web (CORS + redirection après login) ---
# En dev, si les cookies de session ne partent pas du navigateur vers l’API (ports différents),
# configure un proxy Vite vers cette API pour tout passer par la même origine que le panel.
# Quand tu ouvres le panel via une IP, mets la même origine ici (ex. http://192.168.0.250:5173).
FRONTEND_URL="http://localhost:5173"

# Secret partagé avec le processus bot (ex. /sendembed). Même valeur dans bot/.env — min. 16 caractères.
VEX_BOT_API_SECRET="change-moi-meme-valeur-que-dans-bot-env"
