# Jeton du bot (section « Bot » du portail Discord, pas le client OAuth)
DISCORD_BOT_TOKEN=

# ID de l’application (General Information → Application ID) — requis pour npm run deploy
DISCORD_CLIENT_ID=

# Développement : ID du serveur où déployer les slash (instantané).
# Production : laisse vide pour un déploiement global (jusqu’à ~1 h de propagation).
DISCORD_GUILD_ID=

# URL de l’API Vex (ex. http://127.0.0.1:3001 en local). Requis pour /sendembed.
API_BASE_URL=http://127.0.0.1:3001
# Même valeur que VEX_BOT_API_SECRET dans api/.env — min. 16 caractères.
VEX_BOT_API_SECRET=
